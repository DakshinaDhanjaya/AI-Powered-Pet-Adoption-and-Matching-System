# Example .env for recommendation_api
# Copy to .env and update values; do NOT commit real credentials.

# Path to the KNN model (pickle)
PET_REC_MODEL_PATH=static/ml/best_knn_model.pkl

# Path to the dataset CSV
PET_REC_DATA_PATH=updated_pet_dataset.csv

# Optional MongoDB URI (if you want live data lookup)
MONGODB_URI=

# Flask settings
PORT=5001
FLASK_DEBUG=0
