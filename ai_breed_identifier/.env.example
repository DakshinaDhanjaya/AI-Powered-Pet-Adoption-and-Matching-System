# Example .env for ai_breed_identifier
# Copy to .env and update values; do NOT commit real secrets.

# Path to the PyTorch model file (keep model out of git or use LFS)
PET_BREED_MODEL_PATH=pet_breed_model_phase1.pth

# Upload folder for temporary images
UPLOAD_FOLDER=uploads

# Flask settings
FLASK_DEBUG=1
PORT=5000
